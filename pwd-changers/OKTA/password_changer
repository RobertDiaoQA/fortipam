config secret password-changer
    edit "Okta Password Changer"
        set type web-api
        config web-change
            edit 1
                set type execute
                set method POST
                set url "$URL/api/v1/users/$USER/credentials/change_password"
                set header "Content-Type: application/json" "Authorization: SSWS $[0].$PASSWORD"
                set body "{   \"oldPassword\": {     \"value\": \"$PASSWORD\"   },   \"newPassword\": {     \"value\": \"$NEWPASSWD\"   } }"
            next
            edit 2
                set type expect
                set expect-code 200
            next
        end
        config web-verify
            edit 1
                set type execute
                set method POST
                set url "$URL/api/v1/authn"
                set header "Content-Type: application/json" "Accept: application/json"
                set body "{   \"username\": \"$USER\",   \"password\": \"$PASSWORD\" }"
            next
            edit 2
                set type expect
                set expect-code 200
            next
        end
    next
end
